# GM provider: ollama (free/local) or claude (Anthropic API key)
GM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
GM_OLLAMA_MODEL=gemma4          # native function calling; pull with: ollama pull gemma4
GM_TEMPERATURE=0.7              # lower (0.2-0.4) = more reliable tool calls; higher = livelier prose

# For the Claude provider instead:
# GM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# GM_CLAUDE_MODEL=claude-sonnet-4-6

# Optional: scene image generation
# OPENAI_API_KEY=sk-...
