# GM provider: ollama (free/local) or claude (Anthropic API key)
GM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
GM_OLLAMA_MODEL=qwen2.5:7b      # a tool-capable model; pull with: ollama pull qwen2.5:7b

# For the Claude provider instead:
# GM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# GM_CLAUDE_MODEL=claude-sonnet-4-6

# Optional: scene image generation
# OPENAI_API_KEY=sk-...
